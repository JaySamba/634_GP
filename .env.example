# ============================================================
# HR Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your real values.
# .env is gitignored — never commit it.
# ============================================================

# --- Anthropic ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Voyage AI (embeddings) ---
VOYAGE_API_KEY=pa-...

# --- Pinecone (vector store) ---
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=hr-agent

# --- Supabase (Postgres for keyword search + history) ---
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
SUPABASE_DB_URL=postgresql://postgres:YOURPASSWORD@db.xxxxx.supabase.co:5432/postgres

# --- App settings ---
HR_DOCUMENTS_FOLDER=/path/to/your/hr/documents
LOG_LEVEL=INFO
